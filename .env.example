# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Demo workspace
DEMO_ORG_ID=your_demo_org_uuid

# OpenAI
OPENAI_API_KEY=sk_your_openai_api_key
# Controls which OpenAI model the estimator uses
OPENAI_MODEL=gpt-5-mini

# Google Maps / Places
GOOGLE_MAPS_API_KEY=your_server_google_maps_api_key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_public_google_maps_api_key

# Resend email service
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=estimates@snapquote.us

# Public app URL
NEXT_PUBLIC_APP_URL=https://snapquote.us
SNAPQUOTE_APP_URL=https://snapquote.us

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_TEAM=price_your_team_monthly_price_id
STRIPE_PRICE_BUSINESS=price_your_business_monthly_price_id
NEXT_PUBLIC_STRIPE_TEAM_ANNUAL_PRICE_ID=price_your_team_annual_price_id
NEXT_PUBLIC_STRIPE_BUSINESS_ANNUAL_PRICE_ID=price_your_business_annual_price_id
STRIPE_CREDIT_PACK_10_PRICE_ID=price_your_10_credit_pack_price_id
STRIPE_CREDIT_PACK_50_PRICE_ID=price_your_50_credit_pack_price_id
STRIPE_CREDIT_PACK_100_PRICE_ID=price_your_100_credit_pack_price_id

# Twilio SMS delivery
TWILIO_ACCOUNT_SID=AC_your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15555550123
# Optional legacy fallback if TWILIO_PHONE_NUMBER is unset
TWILIO_FROM_NUMBER=+15555550123

# Cloudflare Turnstile bot protection
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# Estimator/debug settings
SNAPQUOTE_ESTIMATOR_AI_MODE=auto
SNAPQUOTE_ESTIMATOR_AUDIT=false
SNAPQUOTE_ESTIMATOR_TEST_AI_CACHE_MODE=off
SNAPQUOTE_ESTIMATOR_TEST_AI_CACHE_DIR=./test-results/_ai-cache

# Estimator test runner settings
SNAPQUOTE_TEST_OUTPUT_DIR=./test-results
SNAPQUOTE_TEST_PROPERTIES_PATH=
SNAPQUOTE_TEST_RUN_LABEL=Ad hoc run
SNAPQUOTE_TEST_LABEL=Ad hoc test
SNAPQUOTE_TEST_SEED=
SNAPQUOTE_TEST_SERVICES=
SNAPQUOTE_TEST_CONTRACTOR_ADDRESS=
SNAPQUOTE_TEST_CONTRACTOR_SLUG=

# Framework-provided runtime variables referenced in server checks; usually leave these unset locally.
# NODE_ENV=development
# NEXT_PHASE=
# NEXT_RUNTIME=nodejs
# VERCEL=1
